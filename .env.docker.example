# Copy to `.env` next to docker-compose.yml on your VPS (e.g. /opt/qaap/.env).
#
#   cp .env.docker.example .env
#   # edit QAAP_OAUTH_PUBLIC_URL and GitHub OAuth app callback
#   docker compose up --build -d

# Host port published to the internet (IDE listens on the same port inside the container).
THEIA_PORT=4873

# Must match how users reach Qaap (used for GitHub OAuth redirects and dev preview URLs).
# Example: http://178.105.136.93:4873
QAAP_OAUTH_PUBLIC_URL=

QAAP_GITHUB_CLIENT_ID=
QAAP_GITHUB_CLIENT_SECRET=
QAAP_SKIP_AUTH=false

# Web Push (generate with: npx web-push generate-vapid-keys)
QAAP_VAPID_PUBLIC_KEY=
QAAP_VAPID_PRIVATE_KEY=
QAAP_VAPID_SUBJECT=mailto:you@example.com

# Background coding agents. The Docker image builds QAIQ (github.com/juancristobalgd1/qaiq)
# and Aider, and auto-detects `codex`, `claude`, `qaiq`, and `aider` on PATH.
# Set provider API keys in this file using the env vars expected by that CLI.
#
# Default background agent (Docker image also sets qaiq as default).
QAAP_DEFAULT_AGENT=qaiq

# --- Provider API keys for @qaiq on the VPS (pick at least one) ---
# These are passed into the container and used when Settings → AI has no value yet.
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# NVIDIA_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_HOST=http://host.docker.internal:11434
# HUGGINGFACE_API_KEY=
#
# Legacy single CLI template. The {prompt} placeholder receives the shell-quoted
# task description. Leave empty to use auto-detected agents and custom list below.
# Examples:
#   QAAP_AGENT_COMMAND=claude -p {prompt}
#   QAAP_AGENT_COMMAND=qaiq --bare --print --dangerously-skip-permissions {qaiq_flags} {prompt}
#   QAAP_AGENT_COMMAND=aider --yes-always --message {prompt}
QAAP_AGENT_COMMAND=

# Optional extra server-side agents as JSON. Use this to expose free-tier/BYOK
# providers through QAIQ, Aider, OpenAI-compatible endpoints, Ollama, OpenRouter,
# etc. QAAP maps known Settings keys into CLI env vars for background jobs.
# Example:
# QAAP_AGENT_COMMANDS=[{"id":"qaiq-gemini","label":"QAIQ Gemini","bin":"qaiq","template":"qaiq --print --dangerously-skip-permissions --provider gemini --model gemini-2.5-flash {prompt}"}]
QAAP_AGENT_COMMANDS=

# Optional: one Docker container per repo (requires Docker socket in the container)
# QAAP_CLOUD_MODE=docker
