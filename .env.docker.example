# Copy to `.env` next to docker-compose.yml on your VPS (e.g. /opt/qaap/.env).
#
#   cp .env.docker.example .env
#   # edit QAAP_OAUTH_PUBLIC_URL and GitHub OAuth app callback
#   docker compose up --build -d

# Host port published to the internet (IDE listens on the same port inside the container).
THEIA_PORT=4873

# Must match how users reach Qaap (used for GitHub OAuth redirects and dev preview URLs).
# Example: http://178.105.136.93:4873
QAAP_OAUTH_PUBLIC_URL=

QAAP_GITHUB_CLIENT_ID=
QAAP_GITHUB_CLIENT_SECRET=
QAAP_SKIP_AUTH=false

# Web Push (generate with: npx web-push generate-vapid-keys)
QAAP_VAPID_PUBLIC_KEY=
QAAP_VAPID_PRIVATE_KEY=
QAAP_VAPID_SUBJECT=mailto:you@example.com

# Optional: one Docker container per repo (requires Docker socket in the container)
# QAAP_CLOUD_MODE=docker
