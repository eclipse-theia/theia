# Nombre visible del IDE (título de la pestaña, bienvenida, barra de título, etc.).
# Tras la primera vez que apliques esta plantilla de código: `npm run build:browser` en la raíz del monorepo.
# A partir de ahí, basta con reiniciar `npm run start:browser` para que los cambios en esta variable surtan efecto.
# Si lo dejas vacío, se usa `theia.frontend.config.applicationName` en package.json.
IDE_APPLICATION_NAME=Qaap

# Icono de marca (favicon, logo junto al menú, ventanas secundarias). Misma regla de arranque/build que arriba.
# Marca vectorial: `./media/qaap-logo.svg` (favicon, splash, barra superior). También URL pública o `./mi-icono.png`.
# En Electron, para icono de ventana nativa usa ruta de archivo local (no http); relativa al directorio de la app, p.ej. `./resources/icon.png`.
IDE_APPLICATION_ICON=./media/qaap-logo.svg

# Omitir pantalla de login en local (solo desarrollo). Reinicia `npm run start:browser` tras cambiar.
QAAP_SKIP_AUTH=true

# GitHub OAuth (callback en GitHub: http://localhost:3000/qaap/oauth/github/callback)
# OAuth App "dev" (solo para desarrollo local). La app de producción vive en el VPS.
QAAP_GITHUB_CLIENT_ID=Ov23litkK5tZGVm72i8G
QAAP_GITHUB_CLIENT_SECRET=0e859cc00d225a800bae62cb1f5e3497ba6a285d
QAAP_OAUTH_PUBLIC_URL=http://localhost:3000

# Carpeta donde se clonan los repos abiertos desde el panel "Projects".
# Por defecto en local: ~/.qaap/workspaces ; en producción: /workspace/repos (montaje del contenedor).
# Descoméntala para forzar otra ruta.
# QAAP_REPOS_ROOT=/Users/jc/.qaap/workspaces
