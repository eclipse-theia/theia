  "description": "Qaap umbrella: add this single dependency to example/browser apps; transitively enables qaap-element-inspector, qaap-mobile-shell, qaap-product-theme. @theia/mini-browser still depends on qaap-element-inspector directly.",
  "dependencies": {
    "@theia/qaap-adapters": "1.71.0",
    "@theia/qaap-extensions": "1.71.0",
    "@theia/qaap-element-inspector": "1.71.0",
    "@theia/qaap-mobile-shell": "1.71.0",
    "@theia/qaap-product-theme": "1.71.0",
    "@theia/qaap-shell": "1.71.0",
    "@theia/core": "1.71.0",
    "tslib": "^2.8.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/qaap-product-frontend-module"
    },
